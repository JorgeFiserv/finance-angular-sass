rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasPaidAccess(userId) {
      return isOwner(userId) &&
        get(/databases/$(database)/documents/users/$(userId)).data.pixAccessGranted == true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId) &&
        (!('pixAccessGranted' in request.resource.data) ||
          request.resource.data.pixAccessGranted == false);

      allow update: if isOwner(userId) &&
        request.resource.data.pixAccessGranted == resource.data.pixAccessGranted;

      allow delete: if false;

      match /legalConsents/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /legalConsentCurrent/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /{document=**} {
        allow read, write: if hasPaidAccess(userId);
      }
    }
  }
}
